{
  "schema_version": 1,
  "stage_keys": [
    "clarify",
    "outline",
    "semantic_deck",
    "quality_rewrite",
    "review_patch"
  ],
  "commands": [
    {
      "command": "make",
      "canonical_command": "v2-make",
      "primary_stage": "clarify",
      "stage_chain": ["clarify", "outline", "semantic_deck", "quality_rewrite", "review_patch"],
      "input_schema": "topic|outline_json + optional brief/audience/theme/slide bounds",
      "output_schema": "outline + semantic deck + compiled deck + rewrite logs + pptx",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "runtime_api_when_llm_mode_set",
      "retry_policy": "v2_generation_internal"
    },
    {
      "command": "batch-make",
      "canonical_command": "batch-make",
      "primary_stage": "clarify",
      "stage_chain": ["clarify", "outline", "semantic_deck", "quality_rewrite", "review_patch"],
      "input_schema": "topic|content_bundle_json + optional multimodal inputs + optional batch_size candidate count",
      "output_schema": "run workspace artifacts (including preprocess/clarify_result.json, planning.json with argument_refs) + final/final.pptx + run_summary.json (+ qa/review_patch/* when --with-ai-review)",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "content_bundle_json_skips_ai_preprocess; with_ai_review_enables_post_export_review_patch; SIE_AUTOPPT_AI_FIVE_STAGE_ENABLED=0 forces legacy path",
      "retry_policy": "orchestrator_state_machine"
    },
    {
      "command": "onepage",
      "canonical_command": "onepage",
      "primary_stage": "semantic_deck",
      "stage_chain": ["clarify", "semantic_deck", "quality_rewrite"],
      "input_schema": "structure_json|deck_spec_json + onepage strategy flags",
      "output_schema": "single-page pptx + review artifacts",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "single_pass"
    },
    {
      "command": "ai-check",
      "canonical_command": "ai-check",
      "primary_stage": "clarify",
      "stage_chain": ["clarify", "outline", "semantic_deck", "quality_rewrite", "review_patch"],
      "input_schema": "topic + optional with_render flag",
      "output_schema": "healthcheck summary json",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "healthcheck_fail_fast"
    },
    {
      "command": "clarify",
      "canonical_command": "clarify",
      "primary_stage": "clarify",
      "stage_chain": ["clarify"],
      "input_schema": "topic + optional clarifier session state",
      "output_schema": "clarify session json",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "clarifier_session"
    },
    {
      "command": "clarify-web",
      "canonical_command": "clarify-web",
      "primary_stage": "clarify",
      "stage_chain": ["clarify"],
      "input_schema": "host/port web service bootstrap",
      "output_schema": "local clarify web endpoint",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "request_level"
    },
    {
      "command": "v2-outline",
      "canonical_command": "v2-outline",
      "primary_stage": "outline",
      "stage_chain": ["clarify", "outline"],
      "input_schema": "topic + optional brief/audience/chapter_count/audience_tier/narrative_pacing/slide bounds",
      "output_schema": "generated_outline.json (pages + story_rationale + outline_strategy)",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "outline_generation"
    },
    {
      "command": "v2-plan",
      "canonical_command": "v2-plan",
      "primary_stage": "semantic_deck",
      "stage_chain": ["clarify", "outline", "semantic_deck"],
      "input_schema": "topic|outline_json + optional batch_size",
      "output_schema": "outline + semantic deck candidate(s) + selected semantic deck + compiled deck",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "single_candidate_when_batch_unavailable",
      "retry_policy": "semantic_generation"
    },
    {
      "command": "v2-compile",
      "canonical_command": "v2-compile",
      "primary_stage": "semantic_deck",
      "stage_chain": ["semantic_deck"],
      "input_schema": "semantic deck json",
      "output_schema": "compiled deck json",
      "ai_execution_mode": "none",
      "requires_api_key": {"agent_first": false, "runtime_api": false, "none": false},
      "fallback_mode": "none",
      "retry_policy": "none"
    },
    {
      "command": "v2-patch",
      "canonical_command": "v2-patch",
      "primary_stage": "review_patch",
      "stage_chain": ["review_patch"],
      "input_schema": "compiled deck json + patch json",
      "output_schema": "patched deck json",
      "ai_execution_mode": "none",
      "requires_api_key": {"agent_first": false, "runtime_api": false, "none": false},
      "fallback_mode": "none",
      "retry_policy": "none"
    },
    {
      "command": "v2-render",
      "canonical_command": "v2-render",
      "primary_stage": "review_patch",
      "stage_chain": ["quality_rewrite", "review_patch"],
      "input_schema": "compiled deck json",
      "output_schema": "review artifacts + optional patched deck + pptx",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "render_gate_fail_fast"
    },
    {
      "command": "v2-make",
      "canonical_command": "v2-make",
      "primary_stage": "clarify",
      "stage_chain": ["clarify", "outline", "semantic_deck", "quality_rewrite", "review_patch"],
      "input_schema": "topic|outline_json + full pipeline options",
      "output_schema": "outline + semantic deck + compiled deck + rewrite logs + pptx",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "v2_generation_internal"
    },
    {
      "command": "v2-review",
      "canonical_command": "v2-review",
      "primary_stage": "review_patch",
      "stage_chain": ["review_patch"],
      "input_schema": "deck json + optional review output dir",
      "output_schema": "review_once.json + patches_review_once.json + patched deck + pptx",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "single_round_review"
    },
    {
      "command": "v2-iterate",
      "canonical_command": "v2-iterate",
      "primary_stage": "review_patch",
      "stage_chain": ["review_patch"],
      "input_schema": "deck json + max_rounds",
      "output_schema": "final review json + final patch json + patched deck + pptx",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "stop_when_no_new_patches",
      "retry_policy": "bounded_rounds"
    },
    {
      "command": "review",
      "canonical_command": "v2-review",
      "primary_stage": "review_patch",
      "stage_chain": ["review_patch"],
      "input_schema": "deck json + optional review output dir",
      "output_schema": "same as v2-review",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "none",
      "retry_policy": "single_round_review"
    },
    {
      "command": "iterate",
      "canonical_command": "v2-iterate",
      "primary_stage": "review_patch",
      "stage_chain": ["review_patch"],
      "input_schema": "deck json + max_rounds",
      "output_schema": "same as v2-iterate",
      "ai_execution_mode": "agent_first",
      "requires_api_key": {"agent_first": false, "runtime_api": true, "none": false},
      "fallback_mode": "stop_when_no_new_patches",
      "retry_policy": "bounded_rounds"
    },
    {
      "command": "visual-draft",
      "canonical_command": "visual-draft",
      "primary_stage": "review_patch",
      "stage_chain": ["quality_rewrite", "review_patch"],
      "input_schema": "deck_spec json + layout/visual flags",
      "output_schema": "preview html/png + optional ai review artifacts",
      "ai_execution_mode": "none",
      "requires_api_key": {"agent_first": false, "runtime_api": false, "none": false},
      "fallback_mode": "with_ai_review_enables_model_review",
      "retry_policy": "single_pass_optional_ai_review"
    }
  ]
}
